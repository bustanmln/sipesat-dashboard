    replacement_infos {
      original_chunk {
        target_content: "@import \"tailwindcss\";"
        replacement_content: "@import \"tailwindcss\";\n\n@import url(\'https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Inter:wght@100..900&display=swap\');\n\n@theme {\n  --color-background: #0f131d;\n  --color-surface-container-lowest: #0a0e18;\n  --color-surface-container-low: #171b26;\n  --color-surface-container: #1c1f2a;\n  --color-surface-container-high: #262a35;\n  --color-surface-container-highest: #313540;\n  --color-surface: #0f131d;\n  --color-surface-dim: #0f131d;\n  --color-surface-variant: #313540;\n  --color-surface-bright: #353944;\n  \n  --color-on-surface: #dfe2f1;\n  --color-on-surface-variant: #baccb0;\n  --color-inverse-surface: #dfe2f1;\n  --color-inverse-on-surface: #2c303b;\n  \n  --color-primary-fixed-dim: #2ae500;\n  --color-primary-container: #39ff14;\n  --color-primary: #efffe3;\n  --color-on-primary: #053900;\n  \n  --color-secondary-container: #00eefc;\n  --color-secondary: #d3fbff;\n  --color-on-secondary: #00363a;\n  --color-secondary-fixed-dim: #00dbe9;\n  \n  --color-tertiary-container: #ffd5b6;\n  --color-tertiary: #fff8f6;\n  --color-on-tertiary-container: #944f00;\n  --color-tertiary-fixed-dim: #ffb77d;\n  \n  --color-error: #ffb4ab;\n  --color-error-container: #93000a;\n  \n  --font-sans: \"Inter\", sans-serif;\n  --font-headline: \"Geist\", sans-serif;\n}\n\n@utility glass-panel {\n  background: rgba(15, 19, 29, 0.6);\n  backdrop-filter: blur(12px);\n  -webkit-backdrop-filter: blur(12px);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n}\n\n@utility neon-glow-primary {\n  box-shadow: 0 0 15px rgba(42, 229, 0, 0.25);\n}\n\n@utility neon-glow-primary-hover {\n  transition: all 0.3s ease;\n}\n\n@utility neon-glow-primary-hover:hover {\n  box-shadow: 0 0 25px rgba(42, 229, 0, 0.55);\n}\n\n@utility neon-glow-secondary {\n  box-shadow: 0 0 15px rgba(0, 238, 252, 0.25);\n}\n\n@utility font-brand-italic {\n  font-family: \"Geist\", sans-serif;\n  font-style: italic;\n}\n\n@keyframes float {\n  0%, 100% { transform: translateY(0px) translateX(0px); opacity: 0.35; }\n  50% { transform: translateY(-40px) translateX(20px); opacity: 0.65; }\n}\n\n@keyframes pulse-ring {\n  0% { transform: scale(0.95); opacity: 0.8; }\n  50% { transform: scale(1.15); opacity: 0.4; }\n  100% { transform: scale(0.95); opacity: 0.8; }\n}\n\n.floating-orb {\n  animation: float 14s ease-in-out infinite;\n}\n\n.floating-orb-delayed {\n  animation: float 18s ease-in-out infinite reverse;\n}\n\n.pulse-dot {\n  animation: pulse-ring 2.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n}\n\n/* Custom scrollbars */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n::-webkit-scrollbar-track {\n  background: rgba(10, 14, 24, 0.5);\n}\n::-webkit-scrollbar-thumb {\n  background: rgba(42, 229, 0, 0.25);\n  border-radius: 9999px;\n}\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(42, 229, 0, 0.5);\n}\n"
      }
